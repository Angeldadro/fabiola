---
import { translations } from "../../i18n/translations";
import ParallaxBlob from "./ParallaxBlob.astro";
import AboutParallax from "./AboutParallax.jsx";

const t = translations.es;
const features = [
  { icon: "croissant", title: t.about.f1Title, desc: t.about.f1Desc },
  { icon: "flame", title: t.about.f2Title, desc: t.about.f2Desc },
  { icon: "coffee", title: t.about.f3Title, desc: t.about.f3Desc },
];

const FEATURE_ICONS = {
  croissant:
    '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>',
  flame:
    '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
  coffee:
    '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>',
};
---

<section id="historia" data-testid="about-section" class="relative py-16 sm:py-20 md:py-28 bg-[#f6efde] overflow-hidden">
  <div class="tex-paper" aria-hidden />
  <ParallaxBlob className="top-10 -left-24" color="#bec8a1" size={360} blur={120} opacity={0.4} />
  <ParallaxBlob className="-bottom-16 right-0" color="#8a987a" size={300} blur={120} opacity={0.18} />

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
    <!-- IMAGE -->
    <AboutParallax client:load />

    <!-- TEXT -->
    <div class="lg:col-span-7 order-1 lg:order-2">
      <span class="text-xs sm:text-sm uppercase tracking-[0.25em] font-medium text-[#8a987a] animate-fade-in">
        — {t.about.overline}
      </span>
      <h2 class="mt-3 sm:mt-4 font-display text-[2.1rem] sm:text-5xl md:text-6xl text-[#2c3425] tracking-tight leading-[1.05] animate-fade-in" style="--d: 0.1s">
        {t.about.title}
      </h2>
      <p class="mt-5 sm:mt-6 text-base sm:text-lg leading-relaxed text-[#4a5440] max-w-xl animate-fade-in" style="--d: 0.2s">
        {t.about.p1}
      </p>
      <p class="mt-3 sm:mt-4 text-sm sm:text-base leading-relaxed text-[#758269] max-w-xl animate-fade-in" style="--d: 0.3s">
        {t.about.p2}
      </p>

      <div class="mt-8 sm:mt-10 grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-5">
        {features.map((f, i) => (
          <div
            class="flex sm:flex-col items-center sm:items-start gap-4 rounded-2xl paper p-4 sm:p-5 hover:-translate-y-1 transition-transform animate-fade-in"
            style={`--d: ${0.4 + i * 0.1}s`}
          >
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[#8a987a] text-[#f6efde]" set:html={FEATURE_ICONS[f.icon]} />
            <div>
              <h3 class="font-display text-lg sm:text-xl text-[#2c3425]">{f.title}</h3>
              <p class="mt-1 text-sm text-[#758269] leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(36px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-fade-in {
    animation: fadeIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) var(--d, 0s) both;
  }
  .animate-scale-in {
    animation: scaleIn 0.6s ease-out 0.2s both;
  }
</style>
