---
// "Fresh from the oven" — flour dust rising, warm god rays, steam wisps
// Generates particles server-side, animates with CSS only

const flourParticles = Array.from({ length: 28 }, (_, i) => ({
  left: Math.random() * 100,
  size: 2 + Math.random() * 4,
  delay: Math.random() * 12,
  duration: 10 + Math.random() * 14,
  drift: (Math.random() - 0.5) * 60,
  opacity: 0.15 + Math.random() * 0.35,
}));

const sugarSparkles = Array.from({ length: 14 }, (_, i) => ({
  left: Math.random() * 100,
  top: Math.random() * 100,
  size: 1 + Math.random() * 2.5,
  delay: Math.random() * 5,
  duration: 3 + Math.random() * 4,
}));

const rays = Array.from({ length: 5 }, (_, i) => ({
  left: 10 + i * 20 + Math.random() * 8,
  width: 80 + Math.random() * 120,
  delay: i * 1.5,
  duration: 8 + Math.random() * 6,
}));
---

<div class="bakery-bg" aria-hidden="true">
  <!-- Warm animated gradient base -->
  <div class="bg-base"></div>

  <!-- God rays (diagonal warm light beams) -->
  <div class="rays-container">
    {rays.map((r) => (
      <div
        class="god-ray"
        style={`left: ${r.left}%; width: ${r.width}px; animation-delay: ${r.delay}s; animation-duration: ${r.duration}s;`}
      />
    ))}
  </div>

  <!-- Warm oven glow pulse -->
  <div class="oven-glow"></div>

  <!-- Flour dust particles rising -->
  <div class="particles">
    {flourParticles.map((p, i) => (
      <div
        class="flour-particle"
        style={`left: ${p.left}%; width: ${p.size}px; height: ${p.size}px; animation-delay: ${p.delay}s; animation-duration: ${p.duration}s; --drift: ${p.drift}px; opacity: ${p.opacity};`}
      />
    ))}
  </div>

  <!-- Sugar crystal sparkles -->
  {sugarSparkles.map((s) => (
    <div
      class="sugar-sparkle"
      style={`left: ${s.left}%; top: ${s.top}%; width: ${s.size}px; height: ${s.size}px; animation-delay: ${s.delay}s; animation-duration: ${s.duration}s;`}
    />
  ))}

  <!-- Steam wisps (SVG) -->
  <svg class="steam-svg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" fill="none">
    <path class="steam-wisp steam-1" d="M200 800 Q220 600 180 400 Q140 200 200 0" stroke="rgba(255,247,230,0.06)" stroke-width="40" stroke-linecap="round" />
    <path class="steam-wisp steam-2" d="M500 800 Q480 550 520 350 Q560 150 500 0" stroke="rgba(255,247,230,0.05)" stroke-width="50" stroke-linecap="round" />
    <path class="steam-wisp steam-3" d="M850 800 Q870 580 830 380 Q790 180 850 0" stroke="rgba(255,247,230,0.04)" stroke-width="35" stroke-linecap="round" />
    <path class="steam-wisp steam-4" d="M1050 800 Q1030 600 1070 400 Q1110 200 1050 0" stroke="rgba(255,247,230,0.05)" stroke-width="45" stroke-linecap="round" />
  </svg>

  <!-- Top fade for seamless transition -->
  <div class="top-fade"></div>
</div>

<style>
  .bakery-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  /* ─── Warm animated gradient ─── */
  .bg-base {
    position: absolute;
    inset: 0;
    background-color: #f4ecd8;
    background-image:
      radial-gradient(45% 50% at 25% 20%, rgba(196, 154, 108, 0.22), transparent 60%),
      radial-gradient(35% 40% at 75% 30%, rgba(138, 152, 122, 0.18), transparent 55%),
      radial-gradient(40% 45% at 50% 80%, rgba(190, 200, 161, 0.25), transparent 60%),
      radial-gradient(30% 35% at 85% 75%, rgba(196, 154, 108, 0.12), transparent 50%);
    background-size: 200% 200%;
    animation: gradientShift 20s ease-in-out infinite alternate;
  }
  @keyframes gradientShift {
    0%   { background-position: 0% 0%; }
    50%  { background-position: 60% 40%; }
    100% { background-position: 30% 80%; }
  }

  /* ─── God rays ─── */
  .rays-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .god-ray {
    position: absolute;
    top: -20%;
    height: 140%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(255, 235, 180, 0.06) 30%,
      rgba(255, 220, 150, 0.04) 60%,
      transparent 100%
    );
    transform: rotate(12deg);
    transform-origin: top center;
    filter: blur(8px);
    animation: rayPulse ease-in-out infinite alternate;
  }
  @keyframes rayPulse {
    0%   { opacity: 0.3; transform: rotate(12deg) scaleX(0.8); }
    100% { opacity: 0.8; transform: rotate(12deg) scaleX(1.3); }
  }

  /* ─── Oven glow ─── */
  .oven-glow {
    position: absolute;
    top: 30%;
    left: 50%;
    width: 700px;
    height: 700px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(196, 154, 108, 0.1) 0%, transparent 65%);
    animation: glowPulse 7s ease-in-out infinite alternate;
  }
  @keyframes glowPulse {
    0%   { transform: translate(-50%, -50%) scale(0.85); opacity: 0.5; }
    100% { transform: translate(-50%, -50%) scale(1.25); opacity: 1; }
  }

  /* ─── Flour particles ─── */
  .particles {
    position: absolute;
    inset: 0;
  }
  .flour-particle {
    position: absolute;
    bottom: -10px;
    border-radius: 50%;
    background: rgba(255, 250, 235, 0.8);
    filter: blur(0.5px);
    animation: flourRise linear infinite;
  }
  @keyframes flourRise {
    0% {
      transform: translateY(0) translateX(0);
      opacity: 0;
    }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% {
      transform: translateY(-100vh) translateX(var(--drift, 0px));
      opacity: 0;
    }
  }

  /* ─── Sugar sparkles ─── */
  .sugar-sparkle {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 245, 220, 0.9);
    box-shadow: 0 0 4px rgba(255, 235, 180, 0.6);
    animation: sparkleTwinkle ease-in-out infinite;
  }
  @keyframes sparkleTwinkle {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    50%      { opacity: 1; transform: scale(1.2); }
  }

  /* ─── Steam wisps ─── */
  .steam-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .steam-wisp {
    animation: steamRise ease-in-out infinite;
  }
  .steam-1 { animation-duration: 9s; animation-delay: 0s; }
  .steam-2 { animation-duration: 11s; animation-delay: 2s; }
  .steam-3 { animation-duration: 10s; animation-delay: 4s; }
  .steam-4 { animation-duration: 12s; animation-delay: 1s; }
  @keyframes steamRise {
    0%, 100% { opacity: 0.3; transform: translateY(20px) scaleX(0.9); }
    50%      { opacity: 1; transform: translateY(-20px) scaleX(1.1); }
  }

  /* ─── Top fade ─── */
  .top-fade {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, #f6efde, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-base, .god-ray, .oven-glow, .flour-particle,
    .sugar-sparkle, .steam-wisp { animation: none !important; }
  }
</style>
