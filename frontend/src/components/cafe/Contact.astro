---
import { translations, BRAND, waLink } from "../../i18n/translations";

const t = translations.es;
const logo = "/logo-dulce.png";
const waHref = waLink("¡Hola Dulce Café! Quisiera más información 🥐");
const dirUrl = `https://www.google.com/maps/dir/?api=1&destination=${BRAND.mapsQuery}`;

const rows = [
  { icon: "map-pin", label: t.contact.addressLabel, value: t.contact.address },
  {
    icon: "phone", label: t.contact.phoneLabel, value: BRAND.phoneDisplay,
    href: `tel:${BRAND.phoneDisplay.replace(/\s|-/g, "")}`,
  },
  { icon: "clock", label: t.contact.hoursLabel, value: t.contact.hours },
];
---

<footer id="contacto" data-testid="contact-section" class="relative bg-brand-olive text-brand-cream pt-16 sm:pt-20 md:pt-28 overflow-hidden">
  <div class="absolute -top-32 right-0 h-[360px] w-[360px] rounded-full bg-brand-sage/25 blur-[120px]" aria-hidden />
  <div class="absolute bottom-0 -left-20 h-[300px] w-[300px] rounded-full bg-brand-pale-sage/15 blur-[120px]" aria-hidden />

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <!-- left -->
      <div>
        <span class="text-xs sm:text-sm uppercase tracking-[0.25em] font-medium text-brand-pale-sage">
          — {t.contact.overline}
        </span>
        <h2 class="mt-3 sm:mt-4 font-display text-[2.1rem] sm:text-5xl md:text-6xl tracking-tight leading-[1.05]">
          <span data-lang="es">{t.contact.title}</span>
          <span data-lang="en">We'll have a coffee ready</span>
        </h2>

        <div class="mt-8 sm:mt-10 space-y-4">
          {rows.map((r) => (
            <div class="flex items-start gap-4 rounded-2xl glass-dark p-4">
              <span class="grid h-11 w-11 place-items-center rounded-full bg-brand-cream/10 text-brand-pale-sage shrink-0">
                {r.icon === "map-pin" && <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>}
                {r.icon === "phone" && <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>}
                {r.icon === "clock" && <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
              </span>
              <div>
                <p class="text-[11px] uppercase tracking-[0.2em] text-brand-pale-sage">{r.label}</p>
                {r.href ? (
                  <a href={r.href} data-testid="contact-phone" class="text-base sm:text-lg text-brand-cream hover:text-brand-pale-sage transition-colors">
                    {r.value}
                  </a>
                ) : (
                  <p class="text-base sm:text-lg text-brand-cream">{r.value}</p>
                )}
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 sm:mt-10 flex flex-wrap gap-3">
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            data-testid="contact-whatsapp"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-brand-sage px-6 py-3.5 text-sm font-medium text-brand-cream hover:bg-brand-sage-dark transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {t.contact.cta}
          </a>

          <a
            href={BRAND.instagram}
            target="_blank"
            rel="noopener noreferrer"
            data-testid="contact-instagram"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-brand-cream/25 px-6 py-3.5 text-sm font-medium text-brand-cream hover:bg-brand-cream/10 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            {BRAND.instagramHandle}
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
        </div>
      </div>

      <!-- map -->
      <div class="rounded-3xl overflow-hidden ring-1 ring-brand-cream/15 shadow-2xl h-[300px] sm:h-[380px] lg:h-[460px]">
        <iframe
          title="Mapa Dulce Café"
          data-testid="contact-map"
          src={`https://www.google.com/maps?q=${BRAND.mapsQuery}&output=embed`}
          class="h-full w-full"
          style="border: 0; filter: saturate(0.85);"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        />
      </div>
    </div>

    <!-- bottom -->
    <div class="mt-14 sm:mt-20 pt-8 border-t border-brand-cream/10 flex flex-col sm:flex-row items-center justify-between gap-6 pb-28 lg:pb-8">
      <div class="flex items-center gap-4">
        <img src={logo} alt="Dulce Café" class="h-16 w-auto object-contain" />
        <div class="leading-tight">
          <p class="font-display text-2xl">Dulce Café</p>
          <p class="text-[11px] uppercase tracking-[0.22em] text-brand-pale-sage">
            {t.contact.tagline}
          </p>
        </div>
      </div>
      <p class="text-xs text-brand-pale-sage text-center sm:text-right">
        © {new Date().getFullYear()} Dulce Café. {t.contact.rights}
      </p>
    </div>
  </div>
</footer>


