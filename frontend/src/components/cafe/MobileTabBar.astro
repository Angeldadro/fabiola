---
import { BRAND } from "../../i18n/translations";

const dirUrl = `https://www.google.com/maps/dir/?api=1&destination=${BRAND.mapsQuery}`;
---

<nav data-testid="mobile-tabbar" class="lg:hidden fixed bottom-0 left-0 right-0 z-50 tabbar-safe">
  <div class="mx-3 mb-3 grid grid-cols-4 gap-1 rounded-2xl glass px-2 py-2 shadow-xl">
    <a href="/menu" class="py-1">
      <span class="flex flex-col items-center gap-1">
        <span class="grid h-9 w-9 place-items-center rounded-xl text-[#4a5440]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
        </span>
        <span class="text-[10px] font-medium text-[#4a5440] leading-none">Menú</span>
      </span>
    </a>
    <a href={`tel:${BRAND.phoneDisplay.replace(/\s|-/g, "")}`} class="py-1">
      <span class="flex flex-col items-center gap-1">
        <span class="grid h-9 w-9 place-items-center rounded-xl text-[#4a5440]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </span>
        <span class="text-[10px] font-medium text-[#4a5440] leading-none">Llámanos</span>
      </span>
    </a>
    <a href="https://wa.me/50767453546?text=%C2%A1Hola%20Dulce%20Caf%C3%A9!%20Quisiera%20hacer%20un%20pedido%20%F0%9F%A5%90" target="_blank" rel="noopener noreferrer" class="py-1">
      <span class="flex flex-col items-center gap-1">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-[#25D366] text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </span>
        <span class="text-[10px] font-medium text-[#4a5440] leading-none">WhatsApp</span>
      </span>
    </a>
    <a href={dirUrl} target="_blank" rel="noopener noreferrer" class="py-1">
      <span class="flex flex-col items-center gap-1">
        <span class="grid h-9 w-9 place-items-center rounded-xl text-[#4a5440]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
        </span>
        <span class="text-[10px] font-medium text-[#4a5440] leading-none">Cómo llegar</span>
      </span>
    </a>
  </div>
</nav>
