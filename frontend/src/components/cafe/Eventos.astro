---
import { translations } from "../../i18n/translations";
import ParallaxBlob from "./ParallaxBlob.astro";

const t = translations.es;
---

<section id="eventos" data-testid="eventos-section" class="relative py-16 sm:py-20 md:py-28 bg-brand-cream overflow-hidden">
  <div class="tex-paper" aria-hidden />
  <ParallaxBlob className="top-10 -left-24" color="#c49a6c" size={320} blur={120} opacity={0.3} />
  <ParallaxBlob className="-bottom-16 right-0" color="#bec8a1" size={280} blur={120} opacity={0.25} />

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12 text-center">
    <span class="text-xs sm:text-sm uppercase tracking-[0.25em] font-medium text-brand-sage reveal fade-up">
      — {t.eventos.overline}
    </span>
    <h2 class="mt-3 sm:mt-4 font-display text-[2.1rem] sm:text-5xl md:text-6xl text-brand-olive tracking-tight leading-[1.05] reveal fade-up" style="transition-delay: 0.1s">
      {t.eventos.title}
    </h2>
    <p class="mt-4 text-base sm:text-lg text-brand-muted max-w-xl mx-auto reveal fade-up" style="transition-delay: 0.2s">
      {t.eventos.subtitle}
    </p>

    <!-- Placeholder cards -->
    <div class="mt-10 sm:mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 max-w-4xl mx-auto">
      <div class="rounded-2xl paper p-6 sm:p-8 text-left reveal fade-up" style="transition-delay: 0.3s">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-accent text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </span>
        <h3 class="mt-4 font-display text-xl text-brand-olive">
          <span data-lang="es">Próximamente</span>
          <span data-lang="en">Coming Soon</span>
        </h3>
        <p class="mt-2 text-sm text-brand-muted leading-relaxed">
          <span data-lang="es">Estamos preparando eventos especiales para ti. ¡Vuelve pronto!</span>
          <span data-lang="en">We're preparing special events for you. Check back soon!</span>
        </p>
      </div>

      <div class="rounded-2xl paper p-6 sm:p-8 text-left reveal fade-up" style="transition-delay: 0.4s">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-sage text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </span>
        <h3 class="mt-4 font-display text-xl text-brand-olive">
          <span data-lang="es">Ofertas Flash</span>
          <span data-lang="en">Flash Offers</span>
        </h3>
        <p class="mt-2 text-sm text-brand-muted leading-relaxed">
          <span data-lang="es">Promociones sorpresa por tiempo limitado. Suscríbete para no perderte ninguna.</span>
          <span data-lang="en">Limited-time surprise promos. Subscribe so you don't miss out.</span>
        </p>
      </div>

      <div class="rounded-2xl paper p-6 sm:p-8 text-left sm:col-span-2 lg:col-span-1 reveal fade-up" style="transition-delay: 0.5s">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-pale-sage text-brand-olive">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <h3 class="mt-4 font-display text-xl text-brand-olive">
          <span data-lang="es">En Local</span>
          <span data-lang="en">In-Store</span>
        </h3>
        <p class="mt-2 text-sm text-brand-muted leading-relaxed">
          <span data-lang="es">Degustaciones, lanzamientos y celebraciones en PH Central Park.</span>
          <span data-lang="en">Tastings, launches and celebrations at PH Central Park.</span>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(36px);
    will-change: opacity, transform;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>


