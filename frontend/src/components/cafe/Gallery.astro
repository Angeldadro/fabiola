---
import { translations } from "../../i18n/translations";
import ParallaxBlob from "./ParallaxBlob.astro";
import GalleryParallax from "./GalleryParallax.jsx";

const t = translations.es;
---

<section id="galeria" data-testid="gallery-section" class="relative py-16 sm:py-20 md:py-28 bg-brand-cream overflow-hidden">
  <div class="tex-paper" aria-hidden />
  <ParallaxBlob className="top-1/3 -right-24" color="#bec8a1" size={380} blur={120} opacity={0.4} />

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12">
    <div class="max-w-2xl mb-8 sm:mb-12">
      <span class="text-xs sm:text-sm uppercase tracking-[0.25em] font-medium text-brand-sage">
        — {t.gallery.overline}
      </span>
      <h2 class="mt-3 sm:mt-4 font-display text-[2.1rem] sm:text-5xl md:text-6xl text-brand-olive tracking-tight leading-[1.05]">
        {t.gallery.title}
      </h2>
      <p class="mt-4 text-base sm:text-lg text-brand-olive-2">{t.gallery.subtitle}</p>
    </div>

    <GalleryParallax client:load />
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
