---
// Blurred image background with Ken Burns slow-zoom + warm gradient overlays
// Feels alive without particles. Image is heavily blurred = atmosphere, not distraction.

export interface Props {
  image: string;
  overlay?: string; // CSS color for gradient overlay
  zoom?: number;    // Ken Burns zoom scale (1.1 = subtle, 1.3 = dramatic)
}

const { image, overlay = "rgba(246,239,222,0.82)", zoom = 1.2 } = Astro.props;
---

<div class="img-bg" aria-hidden="true">
  <div class="img-layer" style={`background-image: url(${image}); --zoom: ${zoom};`}></div>
  <div class="overlay" style={`background: linear-gradient(135deg, ${overlay} 0%, rgba(234,226,204,0.75) 50%, ${overlay} 100%);`}></div>
  <div class="light-sweep"></div>
  <div class="top-fade"></div>
  <div class="bottom-fade"></div>
</div>

<style>
  .img-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  /* Blurred image with slow Ken Burns zoom */
  .img-layer {
    position: absolute;
    inset: -10%;
    background-size: cover;
    background-position: center;
    filter: blur(18px) saturate(1.4) brightness(1.08);
    transform: scale(var(--zoom));
    animation: kenBurns 25s ease-in-out infinite alternate;
  }
  @keyframes kenBurns {
    0%   { transform: scale(var(--zoom)) translate(0, 0); }
    50%  { transform: scale(calc(var(--zoom) + 0.08)) translate(-2%, 1%); }
    100% { transform: scale(calc(var(--zoom) + 0.05)) translate(2%, -1%); }
  }

  /* Warm gradient overlay to keep brand palette dominant */
  .overlay {
    position: absolute;
    inset: 0;
  }

  /* Slow light sweep across the surface */
  .light-sweep {
    position: absolute;
    top: 0;
    left: -50%;
    width: 200%;
    height: 100%;
    background: linear-gradient(
      100deg,
      transparent 30%,
      rgba(255, 240, 200, 0.08) 45%,
      rgba(255, 235, 180, 0.12) 50%,
      rgba(255, 240, 200, 0.08) 55%,
      transparent 70%
    );
    animation: sweep 12s ease-in-out infinite;
  }
  @keyframes sweep {
    0%, 100% { transform: translateX(-30%); }
    50%      { transform: translateX(30%); }
  }

  .top-fade {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 100px;
    background: linear-gradient(to bottom, #f6efde, transparent);
  }
  .bottom-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 100px;
    background: linear-gradient(to top, #f6efde, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .img-layer, .light-sweep { animation: none !important; }
  }
</style>
