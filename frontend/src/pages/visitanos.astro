---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/cafe/Navbar.astro";
import Contact from "../components/cafe/Contact.astro";
import MobileTabBar from "../components/cafe/MobileTabBar.astro";
import WhatsAppButton from "../components/cafe/WhatsAppButton.astro";
import PageHeader from "../components/cafe/PageHeader.astro";
import { translations, BRAND, waLink } from "../i18n/translations";
import { DAY_KEYS } from "../data/menu";

const t = translations.es;
const ten = translations.en;
const p = t.pages.visitanos;
const pen = ten.pages.visitanos;
const c = t.contact;
const cen = ten.contact;

const dirUrl = `https://www.google.com/maps/dir/?api=1&destination=${BRAND.mapsQuery}`;
const wazeUrl = "https://waze.com/ul?q=PH%20Central%20Park%20Transistmica%20Panama&navigate=yes";
const waHref = waLink("¡Hola Dulce Café! Quisiera coordinar un pedido 🥐");
const waHrefEn = waLink("Hello Dulce Café! I'd like to arrange an order 🥐");
---

<BaseLayout
  title="Visítanos · Dulce Café — PH Central Park, Transístmica, Panamá"
  description="Ubicación, horario y cómo llegar a Dulce Café en PH Central Park, Transístmica, Panamá. Abierto todos los días 6:00 a.m. – 10:00 p.m. Pedidos por WhatsApp."
>
  <Navbar />
  <PageHeader
    overline={p.overline} title={p.title} subtitle={p.subtitle}
    overlineEn={pen.overline} titleEn={pen.title} subtitleEn={pen.subtitle}
  />

  <section data-testid="visitanos-page" class="relative bg-brand-cream py-12 sm:py-16 overflow-hidden">
    <div class="tex-paper" aria-hidden />
    <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12 grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">
      <!-- map + directions -->
      <div>
        <div class="rounded-3xl overflow-hidden ring-1 ring-brand-border shadow-xl h-[320px] sm:h-[420px]">
          <iframe
            title="Mapa Dulce Café"
            data-testid="visitanos-map"
            src={`https://www.google.com/maps?q=${BRAND.mapsQuery}&output=embed`}
            class="h-full w-full"
            style="border: 0; filter: saturate(0.9);"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          />
        </div>
        <div class="mt-4 flex flex-col sm:flex-row gap-3">
          <a
            href={dirUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-testid="directions-google"
            class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-brand-olive px-6 py-3.5 text-sm font-medium text-brand-cream hover:bg-brand-olive-2 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
            <span data-lang="es">{p.directions}</span>
            <span data-lang="en">{pen.directions}</span>
          </a>
          <a
            href={wazeUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-testid="directions-waze"
            class="flex-1 inline-flex items-center justify-center gap-2 rounded-full border border-brand-sage px-6 py-3.5 text-sm font-medium text-brand-olive hover:bg-brand-sage hover:text-brand-cream transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span data-lang="es">{p.waze}</span>
            <span data-lang="en">{pen.waze}</span>
          </a>
        </div>
      </div>

      <!-- info -->
      <div>
        <div class="rounded-3xl glass p-6 sm:p-7">
          <div class="flex items-start gap-4">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-brand-sage text-brand-cream shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <p class="text-[11px] uppercase tracking-[0.2em] text-brand-sage">
                <span data-lang="es">{c.addressLabel}</span>
                <span data-lang="en">{cen.addressLabel}</span>
              </p>
              <p class="text-base sm:text-lg text-brand-olive">
                <span data-lang="es">{c.address}</span>
                <span data-lang="en">PH Central Park, Transístmica, Panama</span>
              </p>
            </div>
          </div>
        </div>

        <!-- hours -->
        <div class="mt-5 rounded-3xl glass p-6 sm:p-7">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-sage"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <h2 class="font-display text-xl text-brand-olive">
              <span data-lang="es">{p.hoursTitle}</span>
              <span data-lang="en">{pen.hoursTitle}</span>
            </h2>
          </div>
          <ul class="mt-4 divide-y divide-brand-border/60">
            {DAY_KEYS.map((d) => (
              <li class="flex items-center justify-between py-2.5 text-sm">
                <span class="text-brand-olive-2">
                  <span data-lang="es">{t.days[d]}</span>
                  <span data-lang="en">{ten.days[d]}</span>
                </span>
                <span class="text-brand-muted">
                  <span data-lang="es">{p.hoursValue}</span>
                  <span data-lang="en">{pen.hoursValue}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Info cards -->
        <div class="mt-5 grid gap-4">
          <div class="flex items-start gap-4 rounded-2xl paper p-5">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-brand-cream-2 text-brand-sage-dark shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <div>
              <p class="font-display text-lg text-brand-olive">
                <span data-lang="es">{p.callTitle}</span>
                <span data-lang="en">{pen.callTitle}</span>
              </p>
              <a href={`tel:${BRAND.phoneDisplay.replace(/\s|-/g, "")}`} class="text-sm text-brand-sage hover:underline">{BRAND.phoneDisplay}</a>
            </div>
          </div>
          <div class="flex items-start gap-4 rounded-2xl paper p-5">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-brand-cream-2 text-brand-sage-dark shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </span>
            <div>
              <p class="font-display text-lg text-brand-olive">
                <span data-lang="es">{p.deliveryTitle}</span>
                <span data-lang="en">{pen.deliveryTitle}</span>
              </p>
              <p class="text-sm text-brand-muted leading-relaxed">
                <span data-lang="es">{p.deliveryDesc}</span>
                <span data-lang="en">{pen.deliveryDesc}</span>
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 rounded-2xl paper p-5">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-brand-cream-2 text-brand-sage-dark shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </span>
            <div>
              <p class="font-display text-lg text-brand-olive">
                <span data-lang="es">{p.parkingTitle}</span>
                <span data-lang="en">{pen.parkingTitle}</span>
              </p>
              <p class="text-sm text-brand-muted leading-relaxed">
                <span data-lang="es">{p.parkingDesc}</span>
                <span data-lang="en">{pen.parkingDesc}</span>
              </p>
            </div>
          </div>
        </div>

        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          data-testid="visitanos-whatsapp"
          class="mt-5 w-full inline-flex items-center justify-center gap-2 rounded-full bg-brand-sage px-6 py-3.5 text-sm font-medium text-brand-cream hover:bg-brand-sage-dark transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span data-lang="es">{c.cta}</span>
          <span data-lang="en">{cen.cta}</span>
        </a>
      </div>
    </div>
  </section>

  <Contact />
  <WhatsAppButton />
  <MobileTabBar />
</BaseLayout>
