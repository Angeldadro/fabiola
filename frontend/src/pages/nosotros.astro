---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/cafe/Navbar.astro";
import Contact from "../components/cafe/Contact.astro";
import MobileTabBar from "../components/cafe/MobileTabBar.astro";
import WhatsAppButton from "../components/cafe/WhatsAppButton.astro";
import PageHeader from "../components/cafe/PageHeader.astro";
import ParallaxBlob from "../components/cafe/ParallaxBlob.astro";
import NosotrosParallax from "../components/cafe/NosotrosParallax.jsx";
import { translations, waLink } from "../i18n/translations";

const t = translations.es;
const ten = translations.en;
const p = t.pages.nosotros;
const pen = ten.pages.nosotros;
const waHref = waLink("¡Hola Dulce Café! Quisiera hacer un pedido 🥐");
---

<BaseLayout
  title="Nosotros · Dulce Café — Panadería Venezolana en Panamá"
  description="Conoce la historia de Dulce Café, panadería y pastelería venezolana artesanal en PH Central Park, Transístmica, Panamá."
>
  <Navbar />
  <PageHeader
    overline={p.overline} title={p.title} subtitle={p.subtitle}
    overlineEn={pen.overline} titleEn={pen.title} subtitleEn={pen.subtitle}
  />

  <!-- Story -->
  <section class="relative bg-brand-cream py-14 sm:py-20 overflow-hidden">
    <div class="tex-paper" aria-hidden />
    <ParallaxBlob className="top-10 -left-24" color="#bec8a1" size={360} blur={120} opacity={0.4} />
    <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-6 order-2 lg:order-1">
        <p class="fluid-body leading-relaxed mb-4 max-w-xl text-brand-olive-2 animate-fade-in">
          <span data-lang="es">{p.p1}</span>
          <span data-lang="en">{pen.p1}</span>
        </p>
        <p class="text-base leading-relaxed mb-4 max-w-xl text-brand-muted animate-fade-in" style="--d: 0.1s">
          <span data-lang="es">{p.p2}</span>
          <span data-lang="en">{pen.p2}</span>
        </p>
        <p class="text-base leading-relaxed mb-4 max-w-xl text-brand-muted animate-fade-in" style="--d: 0.2s">
          <span data-lang="es">{p.p3}</span>
          <span data-lang="en">{pen.p3}</span>
        </p>
      </div>
      <NosotrosParallax client:load />
    </div>
  </section>

  <!-- Quote -->
  <section class="relative bg-brand-olive text-brand-cream py-16 sm:py-24 overflow-hidden">
    <ParallaxBlob className="-top-20 right-1/4" color="#8a987a" size={340} blur={120} opacity={0.25} />
    <div class="relative z-10 max-w-4xl mx-auto px-5 sm:px-8 text-center">
      <p class="font-display fluid-h2 leading-tight italic">
        <span data-lang="es">"{p.quote}"</span>
        <span data-lang="en">"{pen.quote}"</span>
      </p>
      <p class="mt-6 text-sm uppercase tracking-[0.25em] text-brand-pale-sage">Dulce Café · 2024</p>
    </div>
  </section>

  <!-- Values -->
  <section class="relative bg-brand-cream py-14 sm:py-20 overflow-hidden">
    <div class="tex-paper" aria-hidden />
    <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12">
      <h2 class="font-display fluid-h2 text-brand-olive tracking-tight text-center">
        <span data-lang="es">{p.valuesTitle}</span>
        <span data-lang="en">{pen.valuesTitle}</span>
      </h2>
      <div class="mt-10 grid sm:grid-cols-3 gap-5">
        {p.values.map((v, i) => (
          <div
            class="rounded-3xl paper p-7 text-center hover:-translate-y-1 transition-transform"
            style={`animation: fadeIn 0.6s ease-out ${i * 0.1}s both;`}
          >
            <span class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-brand-sage text-brand-cream">
              {i === 0 && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
              )}
              {i === 1 && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
              {i === 2 && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              )}
            </span>
            <h3 class="mt-5 font-display text-2xl text-brand-olive">
              <span data-lang="es">{v.title}</span>
              <span data-lang="en">{pen.values[i]?.title || v.title}</span>
            </h3>
            <p class="mt-2 text-sm text-brand-muted leading-relaxed">
              <span data-lang="es">{v.desc}</span>
              <span data-lang="en">{pen.values[i]?.desc || v.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative mesh-bg py-16 sm:py-24 overflow-hidden">
    <div class="relative z-10 max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <h2 class="font-display fluid-h2 text-brand-olive tracking-tight">
        <span data-lang="es">{p.ctaTitle}</span>
        <span data-lang="en">{pen.ctaTitle}</span>
      </h2>
      <p class="mt-4 fluid-body text-brand-olive-2">
        <span data-lang="es">{p.ctaSubtitle}</span>
        <span data-lang="en">{pen.ctaSubtitle}</span>
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          data-testid="nosotros-whatsapp"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-brand-olive px-7 py-4 text-sm font-medium text-brand-cream hover:bg-brand-olive-2 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span data-lang="es">{t.nav.order}</span>
          <span data-lang="en">{ten.nav.order}</span>
        </a>
        <a
          href="/visitanos"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-brand-sage px-7 py-4 text-sm font-medium text-brand-olive hover:bg-brand-sage hover:text-brand-cream transition-colors"
        >
          <span data-lang="es">{t.nav.contact}</span>
          <span data-lang="en">{ten.nav.contact}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <Contact />
  <WhatsAppButton />
  <MobileTabBar />
</BaseLayout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fadeIn 0.7s ease-out var(--d, 0s) both; }
</style>
